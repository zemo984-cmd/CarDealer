# ============================================================
# DATABASE
# ============================================================
# mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:bmw%20series%205@localhost:3306/cardealer"

# ============================================================
# NEXT AUTH
# ============================================================
# عنوان الموقع — غيّره للإنتاج
NEXTAUTH_URL="http://localhost:3001"

# مفتاح سري عشوائي — لا تغيّره بعد ما تبدأ الإنتاج
# لتوليد مفتاح جديد: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_USE_openssl_rand_base64_32"

# ============================================================
# GOOGLE OAUTH (اختياري — إذا تريد تسجيل الدخول بـ Google)
# أنشئ credentials من: https://console.cloud.google.com
# ============================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
