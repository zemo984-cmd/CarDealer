    "privacy_page": {
        "title": "Privacy Policy",
        "effective_date": "Effective Date:",
        "intro": "Welcome to AutoMotive. We are committed to protecting your personal information and your right to privacy. If you have any questions or concerns about this privacy notice, or our practices with regards to your personal information, please contact us.",
